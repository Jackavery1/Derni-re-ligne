{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": [
        "js/types.js",
        "js/logique-pure.js",
        "js/moteur-piece.js",
        "js/progression.js",
        "js/ecrans-config.js",
        "js/actions-jeu.js",
        "js/archi-logique.js",
        "js/bus-jeu.js",
        "js/store-core.js",
        "js/store-etat-partie.js",
        "js/store-refs-canvas.js"
    ],
    "exclude": ["node_modules", "dist", "coverage"]
}
