{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "strict": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "alwaysStrict": true,
        "noImplicitThis": true,
        "useUnknownInCatchVariables": true,
        "skipLibCheck": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
    "include": ["js/**/*.js"],
    "exclude": ["node_modules", "dist", "coverage"]
}
