{
    "name": "tetris-neo",
    "version": "2.4.2",
    "type": "module",
    "description": "Tetris moderne en Vanilla JS — PWA hors-ligne",
    "private": true,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "start": "serve . -p 3000",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{js,mjs,html,css,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,mjs,html,css,json,md}\"",
        "release": "node scripts/release.mjs",
        "sync:sw": "node scripts/generate-sw-cache.mjs",
        "build": "node scripts/build.mjs",
        "typecheck": "tsc --noEmit -p jsconfig.json",
        "prepare:e2e": "playwright install chromium",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{html,css,json,md}": [
            "prettier --write"
        ]
    },
    "license": "MIT",
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.49.0",
        "@vitest/coverage-v8": "^4.1.8",
        "esbuild": "^0.25.0",
        "eslint": "^9.17.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "prettier": "^3.4.2",
        "serve": "^14.2.4",
        "typescript": "^5.7.3",
        "vitest": "^4.1.8"
    }
}
