{
    "name": "derniere-ligne",
    "version": "2.5.15",
    "type": "module",
    "description": "Dernière Ligne — Tetris narratif, PWA hors-ligne",
    "private": true,
    "devServer": {
        "url": "http://127.0.0.1:3000",
        "config": "serve.json",
        "cleanUrls": false,
        "note": "Préférer 127.0.0.1 à localhost (HSTS). Rechargement forcé après MAJ du SW."
    },
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "prestart": "node scripts/exporter-donnees-json.mjs",
        "pretest": "node scripts/exporter-donnees-json.mjs",
        "start": "serve . -c serve.json -l tcp://127.0.0.1:3000",
        "sync:data": "node scripts/exporter-donnees-json.mjs",
        "verify:versions": "node scripts/verifier-versions.mjs",
        "verify:data": "node scripts/verifier-sync-textes.mjs",
        "check:circular": "madge --circular --extensions js js/main.js",
        "check:outdated": "npm outdated || exit 0",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:smoke": "playwright test e2e/smoke.spec.mjs",
        "test:e2e:smoke:dist": "node scripts/run-e2e-dist.mjs e2e/smoke.spec.mjs",
        "test:e2e:perf": "node scripts/run-e2e-dist.mjs e2e/perf.spec.mjs",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{js,mjs,html,css,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,mjs,html,css,json,md}\"",
        "release": "node scripts/release.mjs",
        "sync:sw": "node scripts/generer-precache.mjs",
        "build:precache": "node scripts/generer-precache.mjs --enforce-budget",
        "build": "node scripts/build.mjs",
        "analyze": "node scripts/analyze.mjs",
        "audit:poids": "node scripts/audit-poids.mjs",
        "media:musique": "node scripts/convertir-musique.mjs",
        "media:scenes": "node scripts/convertir-scenes.mjs",
        "media:polices": "node scripts/preparer-polices.mjs",
        "typecheck": "tsc --noEmit -p jsconfig.json",
        "typecheck:migrate": "node scripts/corriger-strict.mjs",
        "prepare:e2e": "node scripts/prepare-e2e.mjs",
        "test:e2e:update": "playwright test --update-snapshots",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,mjs}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{html,css,json,md}": [
            "prettier --write"
        ]
    },
    "license": "UNLICENSED",
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.49.0",
        "@vitest/coverage-v8": "^4.1.8",
        "esbuild": "^0.25.0",
        "eslint": "^9.17.0",
        "globals": "^15.14.0",
        "husky": "^9.1.7",
        "lint-staged": "^15.4.3",
        "madge": "^8.0.0",
        "prettier": "^3.4.2",
        "serve": "^14.2.4",
        "sharp": "^0.34.2",
        "@fontsource/crimson-pro": "^5.2.5",
        "@fontsource/orbitron": "^5.2.5",
        "@fontsource/press-start-2p": "^5.2.5",
        "@fontsource/rajdhani": "^5.2.5",
        "typescript": "^5.7.3",
        "vitest": "^4.1.8"
    }
}
