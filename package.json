{
    "name": "tetris-neo",
    "version": "2.4.2",
    "type": "module",
    "description": "Tetris moderne en Vanilla JS — PWA hors-ligne",
    "private": true,
    "scripts": {
        "start": "serve . -p 3000",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{js,mjs,html,css,json,md}\"",
        "format:check": "prettier --check \"**/*.{js,mjs,html,css,json,md}\"",
        "release": "node scripts/release.mjs",
        "prepare:e2e": "playwright install chromium"
    },
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@playwright/test": "^1.49.0",
        "@vitest/coverage-v8": "^2.1.8",
        "eslint": "^9.17.0",
        "globals": "^15.14.0",
        "prettier": "^3.4.2",
        "serve": "^14.2.4",
        "vitest": "^2.1.8"
    }
}
